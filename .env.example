# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
#
# Copy this file to .env and customize as needed.
#
# USAGE:
#   cp .env.example .env
#   docker-compose up -d
#
# DATABASE:
#   This setup uses Neon PostgreSQL (cloud) - no local database container!
#   1. Create free account at https://neon.tech
#   2. Create a project and get your connection string
#   3. Set DATABASE_URL in apps/ptah-license-server/.env
#
# =============================================================================

# =============================================================================
# NEON POSTGRESQL CONFIGURATION
# =============================================================================
# API key for Neon MCP server and CLI operations
# Get your API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=your_neon_api_key_here
NEON_PROJECT_ID=your_neon_project_id_here

# =============================================================================
# LICENSE SERVER CONFIGURATION
# =============================================================================

# Host port mapping for the API server
# Access the API at: http://localhost:${LICENSE_SERVER_PORT}/api
LICENSE_SERVER_PORT=3000

# =============================================================================
# NGROK CONFIGURATION (WEBHOOK TESTING)
# =============================================================================
# ngrok exposes your local license server to the internet via HTTPS tunnel
# This is required for testing Paddle webhooks locally
#
# SETUP INSTRUCTIONS:
#   1. Create free account: https://dashboard.ngrok.com/signup
#   2. Get your authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
#   3. Copy the authtoken below
#   4. Start with webhook-testing profile: docker-compose --profile webhook-testing up -d
#   5. Get public URL: docker-compose logs ngrok | grep "url="
#   6. Configure Paddle webhook URL to: https://YOUR-URL.ngrok.io/webhooks/paddle
#
# NOTE: Free ngrok accounts get random URLs that change on restart
# For static URLs, upgrade to ngrok paid plan ($8/month for reserved domain)
#
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
