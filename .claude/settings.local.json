{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "mcp__sequential-thinking__sequentialthinking",
      "Bash(cat:*)",
      "Bash(npx nx build:*)",
      "Bash(npx tsc:*)",
      "WebSearch",
      "Bash(npm run build:all:*)",
      "Bash(find:*)",
      "Bash(npx nx test:*)",
      "Bash(git add:*)",
      "Bash(git reset:*)",
      "Bash(git commit:*)",
      "Bash(npm run lint:all:*)",
      "Bash(npx nx:*)",
      "Bash(npx eslint:*)",
      "Bash(npm run build:*)",
      "Bash(node:*)",
      "mcp__daisyui__fetch_daisyui_documentation",
      "Bash(powershell -Command:*)",
      "mcp__daisyui__search_daisyui_documentation",
      "Bash(mkdir:*)",
      "WebFetch(domain:code.visualstudio.com)",
      "WebFetch(domain:vshaxe.github.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:spin.atomicobject.com)",
      "WebFetch(domain:angular.love)",
      "Bash(npm run typecheck:all:*)",
      "WebFetch(domain:api.github.com)",
      "Bash(npx prisma generate:*)",
      "Bash(ffmpeg -i D:/projects/ptah-extension/apps/ptah-landing-page/public/assets/videos/ptah-mcp-server.mp4 -c:v libx264 -profile:v high -pix_fmt yuv420p -vf \"scale=1088:672\" -r 24 -crf 28 -preset slow -an -movflags +faststart D:/projects/ptah-extension/apps/ptah-landing-page/public/assets/videos/ptah-mcp-server_compressed.mp4 -y)",
      "Bash(ls:*)",
      "Bash(cd:*)"
    ],
    "deny": [],
    "ask": [],
    "additionalDirectories": ["D:\\projects\\ptah-extension"]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["sequential-thinking", "angular-cli", "daisyui"],
  "outputStyle": "default"
}
