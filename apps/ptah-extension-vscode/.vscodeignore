# Source files (not in dist)
src/**
**/*.map
tsconfig*.json
project.json

# Development files
.vscode/**
.vscode-test/**
.gitignore
.eslintrc*
.prettierrc*

# Build intermediates
out/**

# Documentation
docs/**
examples/**
CLAUDE.md

# Tests
**/*.test.js
**/*.spec.js
**/test/**
**/tests/**
**/__tests__/**

# Git
.git/**
.github/**

# OS files
.DS_Store
Thumbs.db

# Source maps (not needed for production)
**/*.map

# Misc
*.vsix
*.log

# node_modules — SDKs are bundled into main.mjs via esbuild (TASK_2025_232).
# Only tree-sitter native modules remain as external dependencies.
# Exclude everything except the prebuilt .node binaries tree-sitter needs.
**/node_modules/**/*.md
**/node_modules/**/*.markdown
**/node_modules/**/README*
**/node_modules/**/CHANGELOG*
**/node_modules/**/LICENSE*
**/node_modules/**/LICENCE*
**/node_modules/**/*.ts
!**/node_modules/**/*.d.ts
**/node_modules/**/*.map
**/node_modules/**/test/**
**/node_modules/**/tests/**
**/node_modules/**/__tests__/**
**/node_modules/**/docs/**
**/node_modules/**/examples/**
**/node_modules/**/.github/**
**/node_modules/**/scripts/**
# tree-sitter: exclude C source, keep prebuilt .node binaries
**/node_modules/tree-sitter*/src/**
**/node_modules/tree-sitter/vendor/**

# Monaco Editor — only used by Electron app, VS Code has its own editor
# Contains eval() and new Function() that trigger marketplace "suspicious content" scanner
**/assets/monaco/**

# Python scripts — executable scripts flagged by marketplace scanner
**/*.py
