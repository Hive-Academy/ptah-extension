# Source files (not in dist)
src/**
**/*.map
tsconfig*.json
project.json

# Development files
.vscode/**
.vscode-test/**
.gitignore
.eslintrc*
.prettierrc*

# Build intermediates
out/**

# Documentation
docs/**
examples/**
CLAUDE.md

# Tests
**/*.test.js
**/*.spec.js
**/test/**
**/tests/**
**/__tests__/**

# Git
.git/**
.github/**

# OS files
.DS_Store
Thumbs.db

# Source maps (not needed for production)
**/*.map

# Misc
*.vsix
*.log

# No node_modules needed - all dependencies bundled into main.mjs, WASM files copied as assets
**/node_modules/**

# Monaco Editor — only used by Electron app, VS Code has its own editor
# Contains eval() and new Function() that trigger marketplace "suspicious content" scanner
**/assets/monaco/**

# Python scripts — executable scripts flagged by marketplace scanner
**/*.py
