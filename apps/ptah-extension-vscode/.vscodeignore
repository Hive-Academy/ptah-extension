# Source files (not in dist)
src/**
**/*.ts
!**/*.js
**/*.map
tsconfig*.json
project.json

# Development files
.vscode/**
.vscode-test/**
.gitignore
.eslintrc*
.prettierrc*

# Build intermediates
out/**

# Documentation
docs/**
examples/**
CLAUDE.md

# Tests
**/*.test.js
**/*.spec.js
**/test/**
**/tests/**
**/__tests__/**

# Git
.git/**
.github/**

# OS files
.DS_Store
Thumbs.db

# Source maps (not needed for production)
**/*.map

# Misc
*.vsix
*.log

# Trim node_modules bloat
**/node_modules/**/*.md
**/node_modules/**/*.markdown
**/node_modules/**/README*
**/node_modules/**/CHANGELOG*
**/node_modules/**/HISTORY*
**/node_modules/**/LICENSE*
**/node_modules/**/LICENCE*
**/node_modules/**/.travis.yml
**/node_modules/**/.eslintrc*
**/node_modules/**/.prettierrc*
**/node_modules/**/.editorconfig
**/node_modules/**/tsconfig.json
**/node_modules/**/*.ts
!**/node_modules/**/*.d.ts
**/node_modules/**/*.map
**/node_modules/**/*.min.js.map
**/node_modules/**/test/**
**/node_modules/**/tests/**
**/node_modules/**/__tests__/**
**/node_modules/**/docs/**
**/node_modules/**/example/**
**/node_modules/**/examples/**
**/node_modules/**/.github/**
**/node_modules/**/scripts/**
**/node_modules/**/*.d.ts.map
**/node_modules/**/.package-lock.json

# SDK CLI binaries — only the SDK JS API is needed, not the CLI tools
# @anthropic-ai/claude-agent-sdk: vendor/ has CLI binary (43 MB), cli.js (13 MB)
**/node_modules/@anthropic-ai/claude-agent-sdk/vendor/**
**/node_modules/@anthropic-ai/claude-agent-sdk/cli.js
**/node_modules/@anthropic-ai/claude-agent-sdk/resvg.wasm
# @github/copilot: CLI binary + bundled tools (237 MB)
**/node_modules/@github/copilot/ripgrep/**
**/node_modules/@github/copilot/prebuilds/**
**/node_modules/@github/copilot/sharp/**
**/node_modules/@github/copilot/clipboard/**
**/node_modules/@github/copilot-win32-x64/**
**/node_modules/@github/copilot-linux-x64/**
**/node_modules/@github/copilot-darwin-arm64/**
**/node_modules/@github/copilot-darwin-x64/**
# @openai/codex: CLI binary (102 MB)
**/node_modules/@openai/codex-win32-x64/**
**/node_modules/@openai/codex-linux-x64/**
**/node_modules/@openai/codex-darwin-arm64/**
**/node_modules/@openai/codex-darwin-x64/**
**/node_modules/@openai/codex/**
# @img/sharp: not needed at runtime
**/node_modules/@img/**
