# Source files (not in dist)
src/**
**/*.map
tsconfig*.json
project.json

# Development files
.vscode/**
.vscode-test/**
.gitignore
.eslintrc*
.prettierrc*

# Build intermediates
out/**

# Documentation
docs/**
examples/**
CLAUDE.md

# Tests
**/*.test.js
**/*.spec.js
**/test/**
**/tests/**
**/__tests__/**

# Git
.git/**
.github/**

# OS files
.DS_Store
Thumbs.db

# Source maps (not needed for production)
**/*.map

# Misc
*.vsix
*.log

# Trim node_modules bloat
**/node_modules/**/*.md
**/node_modules/**/*.markdown
**/node_modules/**/README*
**/node_modules/**/CHANGELOG*
**/node_modules/**/HISTORY*
**/node_modules/**/LICENSE*
**/node_modules/**/LICENCE*
**/node_modules/**/.travis.yml
**/node_modules/**/.eslintrc*
**/node_modules/**/.prettierrc*
**/node_modules/**/.editorconfig
**/node_modules/**/tsconfig.json
**/node_modules/**/*.ts
!**/node_modules/**/*.d.ts
**/node_modules/**/*.map
**/node_modules/**/*.min.js.map
**/node_modules/**/test/**
**/node_modules/**/tests/**
**/node_modules/**/__tests__/**
**/node_modules/**/docs/**
**/node_modules/**/example/**
**/node_modules/**/examples/**
**/node_modules/**/.github/**
**/node_modules/**/scripts/**
**/node_modules/**/*.d.ts.map
**/node_modules/**/.package-lock.json

# Monaco Editor — only used by Electron app, VS Code has its own editor
# Contains eval() and new Function() that trigger marketplace "suspicious content" scanner
**/assets/monaco/**

# Python scripts — executable scripts flagged by marketplace scanner
**/*.py

# Native module C source files — prebuilt binaries are used at runtime
**/node_modules/tree-sitter*/src/**
**/node_modules/tree-sitter/vendor/**
