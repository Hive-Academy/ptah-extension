{
  "name": "ptah-extension-vscode",
  "displayName": "Ptah - Claude Code GUI",
  "description": "Complete visual interface for Claude Code CLI with chat, command building, and intelligent context management",
  "version": "0.1.0",
  "publisher": "ptah-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hive-Academy/ptah-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Hive-Academy/ptah-extension/issues"
  },
  "homepage": "https://github.com/Hive-Academy/ptah-extension#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Chat",
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "chat",
    "code-review",
    "assistant",
    "anthropic",
    "cli-gui"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./main.js",
  "icon": "assets/images/ptah-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptah",
          "title": "Ptah",
          "icon": "assets/images/ptah-icon.png"
        }
      ]
    },
    "views": {
      "ptah": [
        {
          "type": "webview",
          "id": "ptah.main",
          "name": "Ptah Code",
          "icon": "$(robot)",
          "contextualTitle": "Ptah"
        }
      ]
    },
    "commands": [
      {
        "command": "ptah.openFullPanel",
        "title": "Open Full Ptah Panel",
        "category": "Ptah",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "ptah.setupAgents",
        "title": "Setup Ptah Agents",
        "category": "Ptah",
        "icon": "$(tools)"
      },
      {
        "command": "ptah.enterLicenseKey",
        "title": "Enter License Key",
        "category": "Ptah",
        "icon": "$(key)"
      },
      {
        "command": "ptah.removeLicenseKey",
        "title": "Remove License Key",
        "category": "Ptah",
        "icon": "$(trash)"
      },
      {
        "command": "ptah.checkLicenseStatus",
        "title": "Check License Status",
        "category": "Ptah",
        "icon": "$(info)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ptah.setupAgents"
        },
        {
          "command": "ptah.enterLicenseKey"
        },
        {
          "command": "ptah.removeLicenseKey"
        },
        {
          "command": "ptah.checkLicenseStatus"
        }
      ],
      "editor/context": [],
      "view/title": [
        {
          "command": "ptah.openFullPanel",
          "when": "view == ptah.main",
          "group": "navigation"
        }
      ]
    },
    "keybindings": []
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0",
    "zod": "^3.25.76"
  }
}
