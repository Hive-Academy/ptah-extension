{
  "name": "ptah-extension-vscode",
  "displayName": "Ptah - Claude Code GUI",
  "description": "Complete visual interface for Claude Code CLI with chat, command building, and intelligent context management",
  "version": "0.1.0",
  "publisher": "ptah-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hive-Academy/ptah-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Hive-Academy/ptah-extension/issues"
  },
  "homepage": "https://github.com/Hive-Academy/ptah-extension#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Chat",
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "chat",
    "code-review",
    "assistant",
    "anthropic",
    "cli-gui"
  ],
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "activationEvents": [
    "onView:ptah.main"
  ],
  "main": "./main.js",
  "icon": "assets/images/ptah-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptah",
          "title": "Ptah - Code Assistant",
          "icon": "assets/images/ptah-icon.png"
        }
      ]
    },
    "views": {
      "ptah": [
        {
          "type": "webview",
          "id": "ptah.main",
          "name": "Ptah Code",
          "icon": "$(robot)",
          "contextualTitle": "Ptah -  Code Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "ptah.quickChat",
        "title": "Quick Chat",
        "category": "Ptah",
        "icon": "$(comment)"
      },
      {
        "command": "ptah.reviewCurrentFile",
        "title": "Review Current File",
        "category": "Ptah",
        "icon": "$(file-code)"
      },
      {
        "command": "ptah.generateTests",
        "title": "Generate Tests",
        "category": "Ptah",
        "icon": "$(beaker)"
      },
      {
        "command": "ptah.buildCommand",
        "title": "Build Command",
        "category": "Ptah",
        "icon": "$(terminal)"
      },
      {
        "command": "ptah.newSession",
        "title": "New Session",
        "category": "Ptah",
        "icon": "$(add)"
      },
      {
        "command": "ptah.includeFile",
        "title": "Include in Context",
        "category": "Ptah",
        "icon": "$(add)"
      },
      {
        "command": "ptah.excludeFile",
        "title": "Exclude from Context",
        "category": "Ptah",
        "icon": "$(remove)"
      },
      {
        "command": "ptah.showAnalytics",
        "title": "Show Analytics",
        "category": "Ptah",
        "icon": "$(graph)"
      },
      {
        "command": "ptah.openFullPanel",
        "title": "Open Full Ptah Panel",
        "category": "Ptah",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ptah.quickChat"
        },
        {
          "command": "ptah.reviewCurrentFile",
          "when": "editorIsOpen"
        },
        {
          "command": "ptah.generateTests",
          "when": "editorIsOpen"
        }
      ],
      "editor/context": [
        {
          "command": "ptah.reviewCurrentFile",
          "group": "ptah@1"
        },
        {
          "command": "ptah.generateTests",
          "group": "ptah@2"
        }
      ],
      "explorer/context": [
        {
          "command": "ptah.includeFile",
          "when": "!ptah.fileIncluded",
          "group": "ptah@1"
        },
        {
          "command": "ptah.excludeFile",
          "when": "ptah.fileIncluded",
          "group": "ptah@1"
        }
      ],
      "view/title": [
        {
          "command": "ptah.newSession",
          "when": "view == ptah.main",
          "group": "navigation"
        },
        {
          "command": "ptah.showAnalytics",
          "when": "view == ptah.main",
          "group": "navigation"
        },
        {
          "command": "ptah.openFullPanel",
          "when": "view == ptah.main",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ptah.quickChat",
        "key": "ctrl+shift+p ctrl+shift+c",
        "mac": "cmd+shift+p cmd+shift+c"
      },
      {
        "command": "ptah.reviewCurrentFile",
        "key": "ctrl+shift+p ctrl+shift+r",
        "mac": "cmd+shift+p cmd+shift+r",
        "when": "editorIsOpen"
      },
      {
        "command": "ptah.buildCommand",
        "key": "ctrl+shift+p ctrl+shift+b",
        "mac": "cmd+shift+p cmd+shift+b"
      }
    ],
    "configuration": {
      "title": "Ptah",
      "properties": {
        "ptah.claudeCliPath": {
          "type": "string",
          "default": "claude",
          "description": "Path to Claude Code CLI executable"
        },
        "ptah.defaultProvider": {
          "type": "string",
          "enum": [
            "anthropic",
            "bedrock",
            "vertex"
          ],
          "default": "anthropic",
          "description": "Default Claude provider"
        },
        "ptah.maxTokens": {
          "type": "number",
          "default": 200000,
          "description": "Maximum tokens per session"
        },
        "ptah.autoIncludeOpenFiles": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include open files in context"
        },
        "ptah.contextOptimization": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic context optimization suggestions"
        },
        "ptah.analyticsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable usage analytics tracking"
        },
        "ptah.claude.model": {
          "type": "string",
          "default": "claude-3-sonnet-20241022",
          "description": "Claude model to use for chat"
        },
        "ptah.claude.temperature": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 1,
          "description": "Temperature setting for Claude responses (0 = deterministic, 1 = creative)"
        },
        "ptah.streaming.bufferSize": {
          "type": "number",
          "default": 8192,
          "minimum": 1024,
          "description": "Stream buffer size in bytes"
        },
        "ptah.streaming.chunkSize": {
          "type": "number",
          "default": 1024,
          "minimum": 256,
          "description": "Stream chunk size in bytes"
        },
        "ptah.streaming.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "description": "Stream timeout in milliseconds"
        },
        "ptah.context.maxFileSize": {
          "type": "number",
          "default": 1048576,
          "minimum": 1024,
          "description": "Maximum file size for context inclusion in bytes"
        },
        "ptah.context.includedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of files included in the current context"
        },
        "ptah.context.excludedFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of files excluded from the current context"
        },
        "ptah.development.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for development"
        },
        "ptah.development.mockResponses": {
          "type": "boolean",
          "default": false,
          "description": "Use mock responses for development testing"
        }
      }
    },
    "languageModelTools": [
      {
        "name": "ptah_analyze_workspace",
        "toolReferenceName": "ptah_analyze_workspace",
        "displayName": "Analyze Workspace",
        "modelDescription": "Analyzes the current workspace to detect project type (React, Angular, NestJS, etc.), frameworks, dependencies, and provides context recommendations. Use this when you need to understand the workspace structure, detect technologies in use, or determine what kind of project you're working with.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "includeHidden": {
              "type": "boolean",
              "description": "Include hidden files and folders in analysis"
            }
          }
        },
        "userDescription": "Analyzes workspace to detect project type and frameworks",
        "icon": "$(search)",
        "canBeReferencedInPrompt": true
      },
      {
        "name": "ptah_search_files",
        "toolReferenceName": "ptah_search_files",
        "displayName": "Search Files",
        "modelDescription": "Searches for files in the workspace matching a query pattern. Supports glob patterns, file extensions, and text search. Use this when you need to find specific files, search by extension (*.ts, *.json), or locate files containing certain names. Returns up to maxResults files with their paths.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query (supports glob patterns like *.ts, **/*.json)"
            },
            "includeImages": {
              "type": "boolean",
              "description": "Include image files in results"
            },
            "maxResults": {
              "type": "number",
              "description": "Maximum number of results to return"
            }
          },
          "required": [
            "query"
          ]
        },
        "userDescription": "Search for files matching a query pattern",
        "icon": "$(search)",
        "canBeReferencedInPrompt": true
      },
      {
        "name": "ptah_get_relevant_files",
        "toolReferenceName": "ptah_get_relevant_files",
        "displayName": "Get Relevant Files",
        "modelDescription": "Suggests files relevant to a specific task or feature. Uses AI-powered relevance scoring to find files that are likely to be important for the given task description. Use this when you need to know which files to examine or modify for a particular feature, bug fix, or implementation task.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "taskDescription": {
              "type": "string",
              "description": "Description of the task or feature to find relevant files for"
            },
            "conversationContext": {
              "type": "string",
              "description": "Additional context from the conversation"
            }
          },
          "required": [
            "taskDescription"
          ]
        },
        "userDescription": "Finds files relevant to a specific task",
        "icon": "$(file-code)",
        "canBeReferencedInPrompt": true
      },
      {
        "name": "ptah_get_diagnostics",
        "toolReferenceName": "ptah_get_diagnostics",
        "displayName": "Get Diagnostics",
        "modelDescription": "Retrieves VS Code diagnostics (errors, warnings, hints) for a specific file or the entire workspace. Use this to understand what problems exist in the code, check for TypeScript errors, linting issues, or other diagnostic information reported by language servers.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "filePath": {
              "type": "string",
              "description": "Optional: specific file path to get diagnostics for. If omitted, returns workspace-wide diagnostics."
            },
            "severity": {
              "type": "string",
              "enum": [
                "error",
                "warning",
                "info",
                "hint"
              ],
              "description": "Filter by diagnostic severity"
            }
          }
        },
        "userDescription": "Gets errors, warnings, and diagnostics for files",
        "icon": "$(warning)",
        "canBeReferencedInPrompt": true
      },
      {
        "name": "ptah_find_symbol",
        "toolReferenceName": "ptah_find_symbol",
        "displayName": "Find Symbol",
        "modelDescription": "Searches for classes, functions, interfaces, types, or variables across the entire workspace. Use this when you need to locate where a specific class, function, or type is defined, or to find all occurrences of a symbol name. Supports filtering by symbol type (class, function, interface, type, variable).",
        "inputSchema": {
          "type": "object",
          "properties": {
            "symbolName": {
              "type": "string",
              "description": "Name of the symbol to search for"
            },
            "symbolType": {
              "type": "string",
              "enum": [
                "class",
                "function",
                "interface",
                "type",
                "variable",
                "any"
              ],
              "description": "Type of symbol to search for (defaults to any)"
            }
          },
          "required": [
            "symbolName"
          ]
        },
        "userDescription": "Finds classes, functions, interfaces, or types in workspace",
        "icon": "$(symbol-class)",
        "canBeReferencedInPrompt": true
      },
      {
        "name": "ptah_get_git_status",
        "toolReferenceName": "ptah_get_git_status",
        "displayName": "Get Git Status",
        "modelDescription": "Retrieves the current git repository status including staged changes, modified files, untracked files, current branch, and commits ahead/behind remote. Use this to understand what changes have been made, what's ready to commit, or to check the state of the working tree before making code changes.",
        "inputSchema": {
          "type": "object",
          "properties": {}
        },
        "userDescription": "Gets current git repository status",
        "icon": "$(git-commit)",
        "canBeReferencedInPrompt": true
      }
    ]
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0",
    "zod": "^3.25.76"
  }
}
