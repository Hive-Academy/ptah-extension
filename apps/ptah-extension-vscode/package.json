{
  "name": "ptah-extension-vscode",
  "displayName": "Ptah - Claude Code GUI",
  "description": "Complete visual interface for Claude Code CLI with chat, command building, and intelligent context management",
  "version": "0.1.0",
  "publisher": "ptah-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hive-Academy/ptah-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Hive-Academy/ptah-extension/issues"
  },
  "homepage": "https://github.com/Hive-Academy/ptah-extension#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Chat",
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "chat",
    "code-review",
    "assistant",
    "anthropic",
    "cli-gui"
  ],
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./main.js",
  "icon": "assets/images/ptah-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptah",
          "title": "Ptah",
          "icon": "assets/images/ptah-icon.png"
        }
      ]
    },
    "views": {
      "ptah": [
        {
          "type": "webview",
          "id": "ptah.main",
          "name": "Ptah Code",
          "icon": "$(robot)",
          "contextualTitle": "Ptah"
        }
      ]
    },
    "commands": [
      {
        "command": "ptah.openFullPanel",
        "title": "Open Full Ptah Panel",
        "category": "Ptah",
        "icon": "$(split-horizontal)"
      }
    ],
    "menus": {
      "commandPalette": [],
      "editor/context": [],
      "view/title": [
        {
          "command": "ptah.openFullPanel",
          "when": "view == ptah.main",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [],
    "configuration": {
      "title": "Ptah",
      "properties": {
        "ptah.mcpPort": {
          "type": "number",
          "default": 51820,
          "minimum": 1024,
          "maximum": 65535,
          "markdownDescription": "Port number for Ptah MCP server (default: 51820). Change if port conflicts occur. **Requires extension reload to take effect.**"
        },
        "ptah.model.selected": {
          "type": "string",
          "enum": [
            "opus",
            "sonnet",
            "haiku"
          ],
          "default": "sonnet",
          "enumDescriptions": [
            "Opus 4.5 - Most capable for complex work",
            "Sonnet 4.5 - Best for everyday tasks (recommended)",
            "Haiku 4.5 - Fastest for quick answers"
          ],
          "markdownDescription": "Default Claude model for new chat sessions."
        },
        "ptah.autopilot.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable autopilot mode to auto-approve certain actions."
        },
        "ptah.autopilot.permissionLevel": {
          "type": "string",
          "enum": [
            "ask",
            "auto-edit",
            "yolo"
          ],
          "default": "ask",
          "enumDescriptions": [
            "Manual - Approval required for each action (safest)",
            "Auto-edit - Auto-approve file edit and write operations",
            "Full Auto (YOLO) - Skip ALL permission prompts (dangerous)"
          ],
          "markdownDescription": "Permission level when autopilot is enabled."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/uuid": "^9.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0",
    "zod": "^3.25.76"
  }
}
