{
  "name": "ptah-coding-orchestra",
  "displayName": "Ptah - The Coding Orchestra",
  "description": "The AI coding orchestra for VS Code. Provider-agnostic AI orchestration with intelligent workspace analysis, Code Execution MCP server, and project-adaptive multi-agent workflows.",
  "version": "0.2.6",
  "publisher": "ptah-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hive-Academy/ptah-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Hive-Academy/ptah-extension/issues"
  },
  "homepage": "https://github.com/Hive-Academy/ptah-extension#readme",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "code-review",
    "assistant",
    "llm",
    "agent",
    "ai-coding",
    "developer-tools",
    "coding-assistant",
    "workspace-analysis",
    "mcp-server",
    "multi-agent"
  ],
  "activationEvents": [
    "onView:ptah.main",
    "onCommand:ptah.openFullPanel",
    "onCommand:ptah.toggleChat",
    "onCommand:ptah.setupAgents",
    "onCommand:ptah.openDashboard"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "preview": true,
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "main": "./main.mjs",
  "icon": "assets/images/ptah-icon.png",
  "contributes": {
    "authentication": [
      {
        "id": "ptah-google",
        "label": "Google (Gemini AI)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ptah",
          "title": "Ptah",
          "icon": "assets/images/ptah-icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "ptah": [
        {
          "type": "webview",
          "id": "ptah.main",
          "name": "Ptah Code",
          "icon": "$(robot)",
          "contextualTitle": "Ptah"
        }
      ]
    },
    "commands": [
      {
        "command": "ptah.toggleChat",
        "title": "Toggle Ptah Chat",
        "category": "Ptah",
        "icon": {
          "light": "assets/images/ptah-icon-toolbar.svg",
          "dark": "assets/images/ptah-icon-toolbar.svg"
        }
      },
      {
        "command": "ptah.openFullPanel",
        "title": "Open Full Ptah Panel",
        "category": "Ptah",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "ptah.setupAgents",
        "title": "Setup Ptah Agents",
        "category": "Ptah",
        "icon": "$(tools)"
      },
      {
        "command": "ptah.enterLicenseKey",
        "title": "Enter License Key",
        "category": "Ptah",
        "icon": "$(key)"
      },
      {
        "command": "ptah.removeLicenseKey",
        "title": "Remove License Key",
        "category": "Ptah",
        "icon": "$(trash)"
      },
      {
        "command": "ptah.checkLicenseStatus",
        "title": "Check License Status",
        "category": "Ptah",
        "icon": "$(info)"
      },
      {
        "command": "ptah.openDashboard",
        "title": "Open Session Analytics Dashboard",
        "category": "Ptah",
        "icon": "$(graph)"
      },
      {
        "command": "ptah.exportSettings",
        "title": "Export Settings",
        "category": "Ptah",
        "icon": "$(export)"
      },
      {
        "command": "ptah.importSettings",
        "title": "Import Settings",
        "category": "Ptah",
        "icon": "$(import)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ptah.setupAgents"
        },
        {
          "command": "ptah.enterLicenseKey"
        },
        {
          "command": "ptah.removeLicenseKey"
        },
        {
          "command": "ptah.checkLicenseStatus"
        },
        {
          "command": "ptah.openDashboard"
        },
        {
          "command": "ptah.exportSettings"
        },
        {
          "command": "ptah.importSettings"
        }
      ],
      "editor/title": [
        {
          "command": "ptah.toggleChat",
          "group": "navigation"
        }
      ],
      "editor/context": [],
      "view/title": [
        {
          "command": "ptah.openFullPanel",
          "when": "view == ptah.main",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [],
    "configuration": {
      "title": "Ptah",
      "properties": {
        "ptah.apiUrl": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Override the Ptah license server URL (e.g., http://localhost:3000 for local development). Defaults to production if not set."
        },
        "ptah.authMethod": {
          "type": "string",
          "enum": [
            "auto",
            "oauth",
            "apiKey",
            "openrouter"
          ],
          "default": "auto",
          "description": "Authentication method for Ptah. 'auto' will try Provider first, then API key."
        },
        "ptah.model.selected": {
          "type": "string",
          "description": "AI model for new chat sessions. Left empty to use the SDK default (set on first initialization)."
        },
        "ptah.autopilot.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable autopilot mode for automatic file edits."
        },
        "ptah.autopilot.permissionLevel": {
          "type": "string",
          "enum": [
            "ask",
            "auto-edit",
            "yolo"
          ],
          "default": "ask",
          "description": "Permission level for autopilot mode."
        },
        "ptah.enhancedPrompts.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable project-specific enhanced prompts (requires Pro license). When enabled, Ptah generates custom guidance based on your codebase to improve AI responses.",
          "scope": "resource"
        },
        "ptah.compaction.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic context compaction for long sessions. When enabled, the AI will summarize conversation history to stay within context limits."
        },
        "ptah.compaction.threshold": {
          "type": "number",
          "default": 100000,
          "minimum": 50000,
          "maximum": 500000,
          "description": "Token threshold to trigger automatic compaction (default: 100,000 tokens)."
        },
        "ptah.reasoningEffort": {
          "type": "string",
          "enum": [
            "",
            "low",
            "medium",
            "high",
            "max"
          ],
          "default": "",
          "description": "Default reasoning effort level for the main AI agent chat. Leave empty for SDK default."
        },
        "ptah.mcpPort": {
          "type": "integer",
          "default": 51820,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for Ptah's MCP server (code execution tools). Must be between 1024-65535. Default: 51820."
        },
        "ptah.agentOrchestration.preferredAgentOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "User's preferred agent order for spawning. First available agent is used. Supports system CLIs and Ptah CLI agent IDs."
        },
        "ptah.agentOrchestration.maxConcurrentAgents": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of concurrent CLI agent processes."
        },
        "ptah.agentOrchestration.geminiModel": {
          "type": "string",
          "default": "",
          "description": "Default model for Gemini CLI agents (e.g. gemini-2.5-pro, gemini-2.5-flash). Leave empty for Gemini's default."
        },
        "ptah.browser.allowLocalhost": {
          "type": "boolean",
          "default": false,
          "description": "Allow AI agent browser automation to access localhost URLs (127.0.0.1, 0.0.0.0, [::1]). Enable for local dev server testing."
        },
        "ptah.browser.recordingDir": {
          "type": "string",
          "default": "",
          "description": "Directory to save browser recording GIFs. Defaults to the system temporary directory when empty."
        },
        "ptah.webSearch.provider": {
          "type": "string",
          "enum": [
            "tavily",
            "serper",
            "exa"
          ],
          "default": "tavily",
          "description": "Web search provider for the ptah_web_search tool. Each provider requires its own API key."
        },
        "ptah.webSearch.maxResults": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "Default number of search results to return (1-20)."
        }
      }
    }
  }
}
