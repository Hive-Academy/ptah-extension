{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Ptah Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/../../dist/apps/ptah-extension-vscode"],
      "outFiles": [
        "${workspaceFolder}/../../dist/apps/ptah-extension-vscode/**/*.js",
        "${workspaceFolder}/../../dist/apps/ptah-extension-vscode/**/*.js.map"
      ],
      "preLaunchTask": "nx: build extension",
      "presentation": {
        "hidden": false,
        "group": "1_debug",
        "order": 1
      }
    },
    {
      "name": "Launch Extension (Development)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/../../dist/apps/ptah-extension-vscode"],
      "outFiles": [
        "${workspaceFolder}/../../dist/apps/ptah-extension-vscode/**/*.js",
        "${workspaceFolder}/../../dist/apps/ptah-extension-vscode/**/*.js.map"
      ],
      "preLaunchTask": "nx: build extension (dev)",
      "presentation": {
        "hidden": false,
        "group": "1_debug",
        "order": 2
      }
    }
  ]
}
