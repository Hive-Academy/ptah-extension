{
  "name": "ptah-electron-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ptah-electron-e2e/src",
  "tags": ["scope:e2e", "type:e2e", "scope:electron", "type:app"],
  "implicitDependencies": ["ptah-electron"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": [
        { "target": "build-dev", "projects": ["ptah-electron"] },
        { "target": "copy-renderer", "projects": ["ptah-electron"] }
      ],
      "options": {
        "cwd": "apps/ptah-electron-e2e",
        "command": "npx playwright test --config=playwright.config.ts"
      },
      "configurations": {
        "ci": {
          "command": "npx playwright test --config=playwright.config.ts --reporter=list"
        }
      }
    },
    "showcase": {
      "executor": "nx:run-commands",
      "dependsOn": [
        { "target": "build-dev", "projects": ["ptah-electron"] },
        { "target": "copy-renderer", "projects": ["ptah-electron"] }
      ],
      "options": {
        "parallel": false,
        "commands": [
          "node apps/ptah-electron-e2e/scripts/clean-recordings.mjs",
          "node scripts/copy-wasm.js dist/apps/ptah-electron",
          "npx playwright test --config=apps/ptah-electron-e2e/showcase.config.ts",
          "node apps/ptah-electron-e2e/scripts/transcode.mjs"
        ]
      }
    },
    "e2e:nightly": {
      "executor": "nx:run-commands",
      "dependsOn": [
        { "target": "build-dev", "projects": ["ptah-electron"] },
        { "target": "copy-renderer", "projects": ["ptah-electron"] }
      ],
      "options": {
        "cwd": "apps/ptah-electron-e2e",
        "command": "npx playwright test --config=playwright.config.ts --grep @nightly"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/ptah-electron-e2e/tsconfig.spec.json"
      }
    }
  }
}
