{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["node", "electron"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true
  },
  "include": [
    "src/**/*.ts",
    "../../libs/backend/vscode-lm-tools/src/lib/code-execution/services/gifenc.d.ts"
  ],
  "exclude": ["src/preload.ts", "**/*.spec.ts"]
}
