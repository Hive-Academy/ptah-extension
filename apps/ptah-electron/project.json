{
  "name": "ptah-electron",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ptah-electron/src",
  "tags": ["scope:electron", "type:app"],
  "targets": {
    "build-main": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ptah-electron",
        "main": "apps/ptah-electron/src/main.ts",
        "outputFileName": "main.mjs",
        "tsConfig": "apps/ptah-electron/tsconfig.build.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "generatePackageJson": true,
        "generateLockfile": true,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "esbuildConfig": "apps/ptah-electron/esbuild.config.cjs",
        "external": [
          "electron",
          "electron-updater",
          "@anthropic-ai/claude-agent-sdk",
          "@github/copilot-sdk",
          "@openai/codex-sdk",
          "deepagents",
          "@langchain/core",
          "@langchain/langgraph",
          "@langchain/openai",
          "@langchain/anthropic",
          "langchain",
          "langsmith",
          "reflect-metadata",
          "tsyringe",
          "async-mutex",
          "cross-spawn",
          "eventemitter3",
          "gray-matter",
          "json2md",
          "jsonrepair",
          "minimatch",
          "picomatch",
          "rxjs",
          "uuid",
          "which",
          "zod",
          "tslib",
          "chokidar",
          "fast-glob",
          "p-limit",
          "p-queue",
          "axios",
          "node-pty",
          "exa-js",
          "gpt-tokenizer",
          "web-tree-sitter",
          "@tavily/core",
          "chrome-launcher",
          "chrome-remote-interface",
          "gifenc",
          "jpeg-js",
          "better-sqlite3",
          "sqlite-vec",
          "croner",
          "ulid",
          "@xenova/transformers",
          "grammy",
          "discord.js",
          "@slack/bolt",
          "ffmpeg-static",
          "nodejs-whisper",
          "bottleneck"
        ],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ptah-electron/src/assets",
            "output": "assets"
          },
          {
            "glob": "**/*",
            "input": "apps/ptah-extension-vscode/assets/plugins",
            "output": "assets/plugins"
          },
          {
            "glob": "**/*",
            "input": "libs/backend/agent-generation/templates",
            "output": "templates"
          },
          {
            "glob": "electron-builder.yml",
            "input": "apps/ptah-electron",
            "output": "."
          }
        ]
      },
      "configurations": {
        "production": {
          "sourcemap": false,
          "minify": true
        },
        "development": {
          "sourcemap": true,
          "minify": false
        }
      }
    },
    "build-preload": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ptah-electron",
        "main": "apps/ptah-electron/src/preload.ts",
        "outputFileName": "preload.js",
        "tsConfig": "apps/ptah-electron/tsconfig.preload.json",
        "format": ["cjs"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": {
            ".js": ".js"
          }
        },
        "external": ["electron"]
      }
    },
    "build-embedder-worker": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ptah-electron",
        "main": "libs/backend/memory-curator/src/lib/embedder/embedder-worker.ts",
        "outputFileName": "embedder-worker.mjs",
        "tsConfig": "apps/ptah-electron/tsconfig.embedder-worker.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "external": ["@xenova/transformers"]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build-main",
        "build-preload",
        "build-embedder-worker",
        "ptah-extension-webview:build"
      ],
      "options": {
        "commands": [
          {
            "command": "node scripts/copy-wasm.js dist/apps/ptah-electron",
            "forwardAllArgs": false
          }
        ],
        "parallel": false
      }
    },
    "build-dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build-main ptah-electron --configuration=development",
          "nx build-preload ptah-electron",
          "nx build-embedder-worker ptah-electron",
          "nx build ptah-extension-webview --configuration=development"
        ],
        "parallel": false
      }
    },
    "copy-renderer": {
      "executor": "nx:run-commands",
      "dependsOn": ["ptah-extension-webview:build"],
      "outputs": ["{workspaceRoot}/dist/apps/ptah-electron/renderer"],
      "options": {
        "command": "node apps/ptah-electron/scripts/copy-renderer.js"
      }
    },
    "rebuild-native": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/ptah-electron/scripts/rebuild-native.js"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node apps/ptah-electron/scripts/rebuild-native.js",
          "nx build-embedder-worker ptah-electron",
          "nx build-dev ptah-electron",
          "node scripts/copy-wasm.js dist/apps/ptah-electron",
          "nx copy-renderer ptah-electron",
          "node apps/ptah-electron/scripts/launch.js"
        ],
        "parallel": false
      }
    },
    "serve:watch": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build-main ptah-electron --configuration=development --watch",
          "nx build-preload ptah-electron --watch",
          "nx build-embedder-worker ptah-electron --watch",
          "nx build ptah-extension-webview --configuration=development --watch"
        ],
        "parallel": true
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "copy-renderer"],
      "options": {
        "command": "electron-builder --config electron-builder.yml --project dist/apps/ptah-electron"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/ptah-electron/tsconfig.app.json"
      }
    },
    "validate-deps": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-main"],
      "options": {
        "command": "node apps/ptah-electron/scripts/validate-deps.js"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ptah-electron/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
