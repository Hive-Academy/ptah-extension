{
  "name": "ptah-electron",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ptah-electron/src",
  "tags": ["scope:electron", "type:app"],
  "targets": {
    "build-main": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ptah-electron",
        "main": "apps/ptah-electron/src/main.ts",
        "outputFileName": "main.mjs",
        "tsConfig": "apps/ptah-electron/tsconfig.build.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          },
          "banner": {
            "js": "import { createRequire } from 'module'; const require = createRequire(import.meta.url);"
          }
        },
        "external": [
          "electron",
          "electron-updater",
          "@anthropic-ai/claude-agent-sdk",
          "@github/copilot-sdk",
          "@openai/codex-sdk",
          "reflect-metadata",
          "tsyringe",
          "async-mutex",
          "cross-spawn",
          "eventemitter3",
          "gray-matter",
          "json2md",
          "jsonrepair",
          "minimatch",
          "picomatch",
          "rxjs",
          "uuid",
          "which",
          "zod",
          "tslib",
          "chokidar",
          "fast-glob",
          "p-limit",
          "p-queue",
          "axios",
          "node-pty"
        ],
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ptah-electron/src/assets",
            "output": "assets"
          },
          {
            "glob": "**/*",
            "input": "apps/ptah-extension-vscode/assets/plugins",
            "output": "assets/plugins"
          },
          {
            "glob": "**/*",
            "input": "libs/backend/agent-generation/templates",
            "output": "templates"
          },
          {
            "glob": "package.json",
            "input": "apps/ptah-electron",
            "output": "."
          },
          {
            "glob": "electron-builder.yml",
            "input": "apps/ptah-electron",
            "output": "."
          },
          {
            "glob": "tree-sitter.wasm",
            "input": "node_modules/@vscode/tree-sitter-wasm/wasm",
            "output": "wasm"
          },
          {
            "glob": "tree-sitter-javascript.wasm",
            "input": "node_modules/@vscode/tree-sitter-wasm/wasm",
            "output": "wasm"
          },
          {
            "glob": "tree-sitter-typescript.wasm",
            "input": "node_modules/@vscode/tree-sitter-wasm/wasm",
            "output": "wasm"
          }
        ]
      },
      "configurations": {
        "production": {
          "sourcemap": false,
          "minify": true
        },
        "development": {
          "sourcemap": true,
          "minify": false
        }
      }
    },
    "build-preload": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ptah-electron",
        "main": "apps/ptah-electron/src/preload.ts",
        "outputFileName": "preload.js",
        "tsConfig": "apps/ptah-electron/tsconfig.preload.json",
        "format": ["cjs"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": {
            ".js": ".js"
          }
        },
        "external": ["electron"]
      }
    },
    "build": {
      "executor": "nx:noop",
      "dependsOn": [
        "build-main",
        "build-preload",
        "ptah-extension-webview:build"
      ]
    },
    "build-dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build-main ptah-electron --configuration=development",
          "nx build-preload ptah-electron",
          "nx build ptah-extension-webview --configuration=development"
        ],
        "parallel": true
      }
    },
    "copy-renderer": {
      "executor": "nx:run-commands",
      "dependsOn": ["ptah-extension-webview:build"],
      "outputs": ["{workspaceRoot}/dist/apps/ptah-electron/renderer"],
      "options": {
        "command": "node apps/ptah-electron/scripts/copy-renderer.js"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build-dev ptah-electron",
          "nx copy-renderer ptah-electron",
          "node apps/ptah-electron/scripts/launch.js"
        ],
        "parallel": false
      }
    },
    "serve:watch": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx build-main ptah-electron --configuration=development --watch",
          "nx build-preload ptah-electron --watch",
          "nx build ptah-extension-webview --configuration=development --watch"
        ],
        "parallel": true
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "copy-renderer"],
      "options": {
        "command": "electron-builder --config electron-builder.yml --project dist/apps/ptah-electron"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/ptah-electron/tsconfig.app.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
