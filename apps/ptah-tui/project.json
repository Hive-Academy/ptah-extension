{
  "name": "ptah-tui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/ptah-tui/src",
  "tags": ["scope:cli", "type:app"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "dependsOn": [{ "projects": ["ptah-cli"], "target": "build" }],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ptah-cli",
        "main": "apps/ptah-tui/src/main.tsx",
        "outputFileName": "tui.mjs",
        "tsConfig": "apps/ptah-tui/tsconfig.build.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": true,
        "deleteOutputPath": false,
        "esbuildOptions": {
          "outExtension": { ".js": ".mjs" },
          "jsx": "automatic",
          "banner": {
            "js": "import 'reflect-metadata'; import { createRequire } from 'module'; import { fileURLToPath as __esm_fileURLToPath } from 'url'; import { dirname as __esm_dirname } from 'path'; const require = createRequire(import.meta.url); const __filename = __esm_fileURLToPath(import.meta.url); const __dirname = __esm_dirname(__filename);"
          }
        },
        "external": [
          "@anthropic-ai/claude-agent-sdk",
          "@openai/codex-sdk",
          "@cursor/sdk",
          "reflect-metadata",
          "tsyringe",
          "async-mutex",
          "cross-spawn",
          "eventemitter3",
          "gray-matter",
          "json2md",
          "jsonrepair",
          "minimatch",
          "picomatch",
          "rxjs",
          "uuid",
          "which",
          "zod",
          "tslib",
          "chokidar",
          "fast-glob",
          "axios",
          "exa-js",
          "gpt-tokenizer",
          "web-tree-sitter",
          "@tavily/core",
          "marked",
          "commander",
          "better-sqlite3",
          "sqlite-vec",
          "croner",
          "ulid",
          "@huggingface/transformers",
          "grammy",
          "discord.js",
          "@slack/bolt",
          "ffmpeg-static",
          "nodejs-whisper",
          "bottleneck",
          "ink",
          "react",
          "ink-text-input",
          "ink-spinner",
          "ink-gradient",
          "ink-big-text",
          "react-devtools-core"
        ],
        "assets": []
      },
      "configurations": {
        "production": {
          "sourcemap": false,
          "minify": true
        },
        "development": {
          "sourcemap": true,
          "minify": false
        }
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx apps/ptah-tui/src/main.tsx"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/ptah-tui/tsconfig.app.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ptah-tui/jest.config.cjs",
        "passWithNoTests": true
      }
    }
  }
}
