{
  "name": "ptah-extension-webview",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "ptah",
  "sourceRoot": "apps/ptah-extension-webview/src",
  "tags": ["scope:webview", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ptah-extension-webview",
        "browser": "apps/ptah-extension-webview/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ptah-extension-webview/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ptah-extension-webview/public"
          }
        ],
        "styles": [
          "apps/ptah-extension-webview/src/styles.css",
          "node_modules/prismjs/themes/prism-tomorrow.css"
        ],
        "scripts": [
          "node_modules/prismjs/prism.js",
          "node_modules/prismjs/components/prism-typescript.min.js",
          "node_modules/prismjs/components/prism-javascript.min.js",
          "node_modules/prismjs/components/prism-json.min.js",
          "node_modules/prismjs/components/prism-bash.min.js",
          "node_modules/prismjs/components/prism-python.min.js",
          "node_modules/prismjs/components/prism-css.min.js",
          "node_modules/prismjs/components/prism-scss.min.js",
          "node_modules/prismjs/components/prism-yaml.min.js",
          "node_modules/prismjs/components/prism-markdown.min.js",
          "node_modules/prismjs/components/prism-jsx.min.js",
          "node_modules/prismjs/components/prism-tsx.min.js",
          "node_modules/prismjs/components/prism-sql.min.js",
          "node_modules/prismjs/components/prism-go.min.js",
          "node_modules/prismjs/components/prism-rust.min.js",
          "node_modules/prismjs/components/prism-java.min.js",
          "node_modules/prismjs/components/prism-xml-doc.min.js"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "600kb",
              "maximumError": "1.2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "16kb"
            }
          ],
          "outputHashing": "none",
          "namedChunks": false,
          "optimization": {
            "scripts": true,
            "styles": {
              "minify": true,
              "inlineCritical": false
            }
          },
          "fileReplacements": [
            {
              "replace": "apps/ptah-extension-webview/src/environments/environment.ts",
              "with": "apps/ptah-extension-webview/src/environments/environment.production.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "outputHashing": "none"
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "ptah-extension-webview:build:production"
        },
        "development": {
          "buildTarget": "ptah-extension-webview:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "ptah-extension-webview:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/ptah-extension-webview/jest.config.ts",
        "tsConfig": "apps/ptah-extension-webview/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ptah-extension-webview:build",
        "staticFilePath": "dist/apps/ptah-extension-vscode/webview/browser",
        "spa": true
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project apps/ptah-extension-webview/tsconfig.app.json"
      }
    }
  }
}
