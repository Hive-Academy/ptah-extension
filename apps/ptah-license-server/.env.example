# Native Admin Dashboard (TASK_2025_290)
# Comma-separated allowlist of emails granted access to /api/v1/admin/*.
# Matches are case-insensitive; whitespace is trimmed. If this var is empty
# or unset, AdminGuard fails closed (403 "Admin access not configured").
ADMIN_EMAILS=abdallah@miramarstaffing.com

# Marketing (TASK_2025_292)
# HS256 secret for unsubscribe JWTs. MUST be at least 32 characters/bytes for security.
UNSUBSCRIBE_TOKEN_SECRET=
# Svix webhook secret from Resend Dashboard. Strip 'whsec_' prefix if present.
RESEND_WEBHOOK_SECRET=
# Physical postal address required by CAN-SPAM/GDPR for marketing footers.
MARKETING_POSTAL_ADDRESS=
# Public host that serves /unsubscribe/:token and /resubscribe/:token.
# Falls back to FRONTEND_URL when unset, then 'https://ptah.live'. Set this
# explicitly in production if the marketing controller lives on a different
# host than the customer portal.
MARKETING_UNSUBSCRIBE_BASE_URL=
