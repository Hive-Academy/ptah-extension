# =============================================================================
# Ptah License Server - Local Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# The .gitignore file should exclude this file.
#
# This file is used by Docker Compose (env_file directive) and can also be
# used for local development outside Docker.
#
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
#
# LOCAL DEVELOPMENT (Docker):
#   DATABASE_URL is set by docker-compose.yml environment directive.
#   Keep this commented when using Docker.
#
# LOCAL DEVELOPMENT (without Docker):
#   Use the line below:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptah_licenses"
#
# PRODUCTION (Neon - Free Tier):
#   Use the pooled connection string from Neon dashboard:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Note: Neon free tier auto-suspends after 5 min, causing ~500ms cold starts.
# This is acceptable for MVP. Upgrade to Neon Launch for always-on compute.

# =============================================================================
# REDIS CONFIGURATION (OPTIONAL)
# =============================================================================
# Redis is NOT REQUIRED for single-instance deployments.
# The license server uses in-memory storage for:
#   - PKCE state (5 min TTL)
#   - Magic link tokens (2 min TTL)
#   - SSE tickets (30 sec TTL)
#
# Only add Redis when scaling to MULTIPLE backend instances.
#
# LOCAL DEVELOPMENT (Docker):
#   REDIS_URL="redis://localhost:6379"
#
# PRODUCTION (Upstash - Free Tier):
#   REDIS_URL="rediss://default:xxx@xxx.upstash.io:6379"
#
# REDIS_URL is intentionally not set - in-memory storage is used by default

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# Server port (default: 3000)
PORT=3000

# Node environment
# Options: development | production | test
NODE_ENV=development

# Frontend URL for redirects after authentication
# Update this to match your local frontend URL
FRONTEND_URL=http://localhost:4200

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# JSON Web Token secret for signing authentication tokens
#
# GENERATE A SECURE SECRET:
#   openssl rand -hex 32
#   OR: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# SECURITY WARNING: Use a unique, cryptographically random value!
# The example value below is NOT secure - replace it immediately.
#
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token expiration time
# Examples: 15m, 1h, 7d, 30d
JWT_EXPIRATION=7d

# =============================================================================
# ADMIN API SECURITY
# =============================================================================
# API key for admin endpoints (license creation, user management, etc.)
#
# GENERATE A SECURE KEY:
#   openssl rand -hex 32
#   OR: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# SECURITY WARNING: Keep this key secret and rotate it periodically!
#
ADMIN_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# WORKOS AUTHENTICATION
# =============================================================================
# WorkOS provides enterprise-ready authentication with SSO, MFA, and more.
#
# SETUP INSTRUCTIONS:
#   1. Create account at: https://workos.com/
#   2. Go to Dashboard: https://dashboard.workos.com/
#   3. Create new environment (Development for local, Production for live)
#   4. Copy API Key from "API Keys" section
#   5. Copy Client ID from "Configuration" -> "OAuth"
#   6. Add redirect URI: http://localhost:3000/api/auth/callback
#
# API Key (starts with sk_test_ for sandbox, sk_live_ for production)
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Client ID (starts with client_)
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OAuth callback URL - must match the redirect URI in WorkOS dashboard
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Optional: Redirect URL after logout
WORKOS_LOGOUT_REDIRECT_URI=http://localhost:4200

# =============================================================================
# PADDLE PAYMENT INTEGRATION
# =============================================================================
# Paddle handles subscription payments and billing.
#
# PRICING MODEL (TASK_2025_128 - Freemium Model):
#   - Community Plan: FREE forever (no Paddle integration needed)
#     Core features: Visual interface, session history, native VS Code integration
#   - Pro Plan: $5/month or $50/year with 14-day trial
#     Premium features: MCP server, workspace intelligence, OpenRouter proxy,
#     setup wizard, cost tracking, project-adaptive agent generation
#
# Pro plan includes a 14-day free trial.
# Community users can use the extension indefinitely at no cost.
#
# SETUP INSTRUCTIONS:
#   1. Create account at: https://www.paddle.com/
#   2. Sandbox (testing): https://sandbox-vendors.paddle.com/
#   3. Production (live): https://vendors.paddle.com/
#   4. Go to Developer Tools -> Authentication -> Create API Key
#   5. Go to Developer Tools -> Webhooks -> New Destination
#   6. Add webhook endpoint: https://your-domain.com/webhooks/paddle
#      NOTE: /webhooks/paddle NOT /api/webhooks/paddle (excluded from global prefix)
#   7. Select events: subscription.created, subscription.activated, subscription.updated,
#      subscription.canceled, subscription.past_due, subscription.paused, subscription.resumed
#   8. Copy the webhook secret
#
# DETAILED GUIDE: See docs/PADDLE_SETUP_SIMPLIFIED.md
#
# API Key (starts with pdl_sbox_ for sandbox, pdl_live_ for production)
PADDLE_API_KEY=pdl_sbox_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret for signature verification (starts with pdl_ntfset_)
PADDLE_WEBHOOK_SECRET=pdl_ntfset_XXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# PADDLE PRICE IDS - FREEMIUM MODEL (TASK_2025_128)
# =============================================================================
# Create these in Paddle Dashboard: Catalog -> Products -> Prices
#
# IMPORTANT: Create 2 prices for the Pro plan only:
#   1. Ptah Pro Monthly ($5/month, 14-day trial)
#   2. Ptah Pro Yearly ($50/year, 14-day trial)
#
# Community plan is FREE and does not require Paddle integration.
#
# After creating each price in Paddle, copy the Price ID (starts with pri_)
# and paste it below.

# Pro Plan Price IDs
# Features: All Community features + MCP server, workspace intelligence,
#           OpenRouter proxy, custom tools, setup wizard, cost tracking
#
# Monthly subscription ($5/month with 14-day trial)
PADDLE_PRICE_ID_PRO_MONTHLY=pri_PRO_MONTHLY_REPLACE_ME
#
# Yearly subscription ($50/year with 14-day trial - save ~17%)
PADDLE_PRICE_ID_PRO_YEARLY=pri_PRO_YEARLY_REPLACE_ME

# =============================================================================
# EMAIL SERVICE (SendGrid)
# =============================================================================
# SendGrid sends transactional emails (license keys, receipts, etc.)
#
# SETUP INSTRUCTIONS:
#   1. Create account at: https://sendgrid.com/
#   2. Go to Settings -> API Keys -> Create API Key
#   3. Select "Restricted Access" and enable "Mail Send" permission
#   4. Copy the API key (starts with SG.)
#
# SECURITY WARNING: API keys are shown only once during creation!
#
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Sender email address (must be verified in SendGrid)
SENDGRID_FROM_EMAIL=ptah@nghive.tech

# Sender display name
SENDGRID_FROM_NAME=Ptah Team

# =============================================================================
# MAGIC LINK CONFIGURATION
# =============================================================================
# Magic links provide passwordless authentication via email

# Time-to-live for magic links in milliseconds
# Default: 120000 (2 minutes) - enough time to open email and click
# Production recommendation: 300000 (5 minutes) for slower email delivery
MAGIC_LINK_TTL_MS=120000
