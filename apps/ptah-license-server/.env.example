# ============================================
# Ptah License Server Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# For Docker development, see: .env.docker.example (project root)
# For Docker license server, see: .env.local.example (this directory)

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
#
# Local development (PostgreSQL running on host):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptah_licenses"
#
# Docker environment (container-to-container):
#   DATABASE_URL="postgresql://postgres:postgres@postgres:5432/ptah_licenses"
#
# Production (use managed PostgreSQL with SSL):
#   DATABASE_URL="postgresql://user:password@host:5432/ptah_licenses?sslmode=require"
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptah_licenses"

# ============================================
# REDIS CONFIGURATION
# ============================================
# Used for session storage, caching, and rate limiting
#
# Local development (Redis running on host):
#   REDIS_URL="redis://localhost:6379"
#
# Docker environment (container-to-container):
#   REDIS_URL="redis://redis:6379"
#
# Production (use managed Redis with password):
#   REDIS_URL="rediss://default:password@host:6379"
#
REDIS_URL="redis://localhost:6379"

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for the license server (default: 3000)
PORT=3000

# Environment mode: development | production | test
NODE_ENV=development

# Frontend URL for redirects after authentication
# Development: http://localhost:4200
# Production: https://ptah.dev (or your domain)
FRONTEND_URL=http://localhost:4200

# ============================================
# JWT CONFIGURATION
# ============================================
# JSON Web Token settings for authentication
#
# SECURITY WARNING: Generate a unique, random secret for production!
# Generate with: openssl rand -hex 32
#
# Example output: a3f8c9d2e1b4a7f6c9d2e1b4a7f6c9d2e1b4a7f6c9d2e1b4a7f6c9d2e1b4a7f6
#
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Token expiration time (default: 7 days)
# Formats: 1d = 1 day, 7d = 7 days, 1h = 1 hour
JWT_EXPIRATION=7d

# ============================================
# ADMIN API SECURITY
# ============================================
# API key for admin endpoints (license creation, user management, etc.)
#
# SECURITY WARNING: Generate a unique, random key for production!
# Generate with: openssl rand -hex 32
#
# This key must be sent in the X-Admin-API-Key header for admin routes
#
ADMIN_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ============================================
# WORKOS AUTHENTICATION
# ============================================
# WorkOS provides secure, enterprise-ready authentication
# with support for SSO, MFA, and OAuth 2.0 with PKCE
#
# Setup Instructions:
# 1. Create account: https://workos.com/
# 2. Access dashboard: https://dashboard.workos.com/
# 3. Create new environment (Development or Production)
# 4. Navigate to "API Keys" section and copy your API Key
# 5. Navigate to "Configuration" -> "OAuth" and copy Client ID
# 6. Add redirect URI in "Configuration" -> "OAuth" -> "Redirect URIs":
#    Development: http://localhost:3000/auth/callback
#    Production: https://your-domain.com/auth/callback
#
# Test mode keys start with: sk_test_
# Live mode keys start with: sk_live_
#
WORKOS_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Optional: URL to redirect after logout (defaults to FRONTEND_URL)
WORKOS_LOGOUT_REDIRECT_URI=http://localhost:4200

# ============================================
# PADDLE PAYMENT INTEGRATION
# ============================================
# Paddle handles subscription payments and tax compliance
#
# Setup Instructions:
# 1. Create account at https://www.paddle.com/
# 2. For testing, use Sandbox: https://sandbox-vendors.paddle.com/
# 3. For production, use: https://vendors.paddle.com/
#
# API Key Setup:
# 1. Go to Developer Tools -> Authentication
# 2. Click "Generate API Key"
# 3. Copy the API key (starts with pdl_sbox_ for sandbox, pdl_live_ for production)
#
# Webhook Setup:
# 1. Go to Developer Tools -> Webhooks -> New Destination
# 2. Set URL: https://your-domain.com/webhooks/paddle
# 3. Select events: subscription.created, subscription.updated, subscription.canceled
# 4. Copy the webhook secret (starts with pdl_ntfset_)
#
# Price IDs Setup:
# 1. Go to Catalog -> Products -> Create Product
# 2. Add prices for each plan (monthly, yearly, etc.)
# 3. Copy the Price ID for each plan (starts with pri_)
#
PADDLE_API_KEY=pdl_sbox_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PADDLE_WEBHOOK_SECRET=pdl_ntfset_XXXXXXXXXXXXXXXXXXXXXXXX

# Price IDs for different subscription tiers
# Find these in: Catalog -> Products -> [Your Product] -> Prices
PADDLE_PRICE_ID_EARLY_ADOPTER=pri_XXXXXXXXXXXXXXXXXXXXXXXX
PADDLE_PRICE_ID_PRO=pri_YYYYYYYYYYYYYYYYYYYYYYYY

# ============================================
# EMAIL SERVICE (SendGrid)
# ============================================
# SendGrid handles transactional emails (license delivery, notifications)
#
# Setup Instructions:
# 1. Create account: https://sendgrid.com/
# 2. Verify your sender email domain
# 3. Go to Settings -> API Keys -> Create API Key
# 4. Required permissions: Mail Send (Full Access)
# 5. Copy the API key (starts with SG.)
#
# IMPORTANT: Verify your sender domain to avoid emails being marked as spam
#
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@ptah.dev
SENDGRID_FROM_NAME=Ptah Team

# ============================================
# MAGIC LINK CONFIGURATION
# ============================================
# Magic links provide passwordless authentication
#
# TTL (Time To Live) in milliseconds
# Default: 30000 (30 seconds) - recommended for security
# Maximum: 300000 (5 minutes) - only use if needed
#
# Note: Shorter TTL is more secure but may cause issues on slow networks
#
MAGIC_LINK_TTL_MS=30000
