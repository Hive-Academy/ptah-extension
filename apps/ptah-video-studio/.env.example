# =============================================================================
# Ptah Video Studio - Pipeline Credentials
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp apps/ptah-video-studio/.env.example apps/ptah-video-studio/.env
#
# NEVER commit .env (the root .gitignore already excludes it everywhere).
#
# Loaded automatically by the pipeline scripts (loadStudioEnv in
# scripts/paths.mjs). Values exported in the shell take precedence, so CI
# secrets and one-off overrides still work.
#
# Deliberately separate from the workspace-root .env: that file belongs to the
# license server and is injected into its Docker container via env_file —
# studio credentials must not leak there.
#
# =============================================================================

# =============================================================================
# ELEVENLABS VOICE CLONING (narrate.mjs --engine elevenlabs)
# =============================================================================
# 1. Create an account at https://elevenlabs.io (paid plan required for
#    commercial use of cloned-voice audio).
# 2. Create an Instant Voice Clone: upload 1-5 minutes of clean speech.
# 3. API key: Profile -> API Keys (starts with sk_).
# 4. Voice id: open the cloned voice and copy its id.
#
ELEVENLABS_API_KEY=sk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PTAH_ELEVENLABS_VOICE_ID=your_voice_id_here

# Optional: default TTS engine so --engine can be omitted.
# Options: kokoro (local, default) | elevenlabs
# PTAH_TTS_ENGINE=elevenlabs

# Optional: ElevenLabs model override (default: eleven_multilingual_v2).
# eleven_turbo_v2_5 is faster/cheaper at slightly lower quality.
# PTAH_ELEVENLABS_MODEL=eleven_turbo_v2_5
