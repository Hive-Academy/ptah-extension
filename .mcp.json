{
  "mcpServers": {
    "sequential-thinking": {
      "command": "cmd.exe",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "angular-cli": {
      "command": "cmd.exe",
      "args": ["/c", "npx", "-y", "@angular/cli", "mcp"]
    },
    "daisyui": {
      "type": "http",
      "url": "https://gitmcp.io/saadeghi/daisyui"
    },
    "paddle": {
      "command": "npx",
      "args": [
        "-y",
        "@paddle/paddle-mcp",
        "--api-key=${PADDLE_API_KEY}",
        "--environment=sandbox",
        "--tools=non-destructive"
      ]
    }
  }
}
