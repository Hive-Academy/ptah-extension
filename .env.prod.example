# =============================================================================
# Ptah License Server - Production Environment
# =============================================================================
# Copy to .env.prod and fill in all values.
# NEVER commit .env.prod to version control!
# =============================================================================

# =============================================================================
# DATABASE (Self-Hosted PostgreSQL)
# =============================================================================
POSTGRES_USER=ptah
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
POSTGRES_DB=ptah_db

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://ptah.live

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRATION=7d

# =============================================================================
# ADMIN API SECURITY
# =============================================================================
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ADMIN_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# WORKOS AUTHENTICATION
# =============================================================================
WORKOS_API_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_CLIENT_ID=client_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_REDIRECT_URI=https://api.ptah.live/api/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=https://ptah.live

# =============================================================================
# PADDLE PAYMENT PROCESSING
# =============================================================================
PADDLE_API_KEY=pdl_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
PADDLE_WEBHOOK_SECRET=pdl_ntfset_XXXXXXXXXXXXXXXXXXXXXXXX
PADDLE_PRICE_ID_PRO_MONTHLY=pri_XXXXXXXXXXXXXXXXXXXXXXXX
PADDLE_PRICE_ID_PRO_YEARLY=pri_XXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# EMAIL SERVICE (Resend)
# =============================================================================
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=help@ptah.live
FROM_NAME=Ptah Team

# =============================================================================
# LICENSE RESPONSE SIGNING (Ed25519)
# =============================================================================
# Signs license verification responses to prevent MITM attacks.
# The VS Code extension embeds the corresponding public key to verify responses.
#
# Generate a key pair with: npx ts-node scripts/generate-license-keys.ts
# Set the private key here (base64-encoded DER PKCS8)
# Set the public key in libs/shared/src/lib/constants/environment.constants.ts
#
LICENSE_SIGNING_PRIVATE_KEY=CHANGE_ME_generate_with_scripts_generate_license_keys

# =============================================================================
# SENTRY ERROR MONITORING (TASK_2025_251)
# =============================================================================
# Create a Sentry project at https://sentry.io and copy the DSN here.
# When empty, Sentry initialization is skipped (safe for local development).
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# =============================================================================
# MAGIC LINK CONFIGURATION
# =============================================================================
MAGIC_LINK_TTL_MS=300000
