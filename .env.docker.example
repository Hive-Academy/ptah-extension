# =============================================================================
# Docker Compose Environment Variables
# =============================================================================
#
# Copy this file to .env.docker and customize as needed.
# Default values work out of the box for local development.
#
# USAGE:
#   cp .env.docker.example .env.docker
#   docker-compose up -d
#
# WINDOWS USERS (WSL2 PERFORMANCE RECOMMENDATION):
#   For optimal Docker performance on Windows, use WSL2 backend and store
#   your project files inside the WSL2 filesystem:
#
#   GOOD:  /home/youruser/projects/ptah-extension/  (WSL2 filesystem)
#   SLOW:  /mnt/c/Users/.../ptah-extension/         (Windows filesystem via WSL)
#   SLOW:  C:\Users\...\ptah-extension\             (Windows filesystem)
#
#   WSL2 provides native Linux I/O performance, while accessing Windows
#   filesystem from WSL2 or Docker has significant overhead (up to 10x slower).
#
#   To move your project to WSL2:
#   1. Open WSL2 terminal: wsl
#   2. Clone your project: cd ~ && git clone <repo> projects/ptah-extension
#   3. Open in VS Code: code ~/projects/ptah-extension
#
# =============================================================================

# =============================================================================
# POSTGRESQL CONFIGURATION
# =============================================================================
# PostgreSQL 16-alpine container settings
# These values are used by both the postgres container and connection strings

# Database superuser username
POSTGRES_USER=postgres

# Database superuser password
# SECURITY: Change this in production!
POSTGRES_PASSWORD=postgres

# Database name for Ptah licenses
POSTGRES_DB=ptah_licenses

# Host port mapping (container always uses 5432 internally)
# Change if you have another PostgreSQL instance on port 5432
POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis 7-alpine container settings

# Host port mapping (container always uses 6379 internally)
# Change if you have another Redis instance on port 6379
REDIS_PORT=6379

# =============================================================================
# LICENSE SERVER CONFIGURATION
# =============================================================================
# NestJS license server container settings

# Host port mapping for the API server
# Access the API at: http://localhost:${LICENSE_SERVER_PORT}/api
LICENSE_SERVER_PORT=3000

# =============================================================================
# DOCKER COMPOSE PROFILES (OPTIONAL)
# =============================================================================
# Uncomment to enable specific profiles
# See docker-compose.yml for profile definitions

# COMPOSE_PROFILES=debug
