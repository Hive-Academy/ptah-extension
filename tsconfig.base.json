{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@ptah-extension/ai-providers-core": [
        "libs/backend/ai-providers-core/src/index.ts"
      ],
      "@ptah-extension/analytics": ["libs/frontend/analytics/src/index.ts"],
      "@ptah-extension/chat": ["libs/frontend/chat/src/index.ts"],
      "@ptah-extension/claude-domain": [
        "libs/backend/claude-domain/src/index.ts"
      ],
      "@ptah-extension/core": ["libs/frontend/core/src/index.ts"],
      "@ptah-extension/dashboard": ["libs/frontend/dashboard/src/index.ts"],
      "@ptah-extension/providers": ["libs/frontend/providers/src/index.ts"],
      "@ptah-extension/session": ["libs/frontend/session/src/index.ts"],
      "@ptah-extension/shared": ["libs/shared/src/index.ts"],
      "@ptah-extension/shared-ui": ["libs/frontend/shared-ui/src/index.ts"],
      "@ptah-extension/vscode-core": ["libs/backend/vscode-core/src/index.ts"],
      "@ptah-extension/workspace-intelligence": [
        "libs/backend/workspace-intelligence/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
