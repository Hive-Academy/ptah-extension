{
  "name": "@ptah-extension/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "landing": "npx nx serve ptah-landing-page",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f license-server",
    "docker:db:start": "docker compose up -d postgres",
    "docker:db:stop": "docker compose stop postgres",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:backup": "bash scripts/backup-db.sh",
    "prisma:generate": "cd apps/ptah-license-server && npx prisma generate",
    "prisma:migrate:dev": "cd apps/ptah-license-server && npx prisma migrate dev",
    "prisma:migrate:deploy": "cd apps/ptah-license-server && npx prisma migrate deploy",
    "prisma:db:push": "cd apps/ptah-license-server && npx prisma db push",
    "prisma:studio": "cd apps/ptah-license-server && npx prisma studio",
    "test:trial-cron": "cd apps/ptah-license-server && npx ts-node ../infra-test/src/main.ts",
    "test:trial-cron:execute": "cd apps/ptah-license-server && npx ts-node ../infra-test/src/main.ts --execute",
    "serve:license-server:short-trial": "TRIAL_DURATION_DAYS=1 nx serve ptah-license-server",
    "build": "nx run-many -t build -p ptah-extension-vscode ptah-extension-webview shared",
    "build:extension": "nx build ptah-extension-vscode",
    "build:webview": "nx build ptah-extension-webview",
    "build:webview:dev": "nx build ptah-extension-webview --configuration=development",
    "build:shared": "nx build shared",
    "build:mcp-test": "nx build infra-test",
    "build:all": "nx run-many -t build",
    "mcp:inspector": "npx @modelcontextprotocol/inspector node dist/apps/infra-test/main.js",
    "dev": "nx run-many -t build -p ptah-extension-vscode ptah-extension-webview --watch",
    "dev:extension": "nx build ptah-extension-vscode --watch",
    "dev:webview": "nx build ptah-extension-webview --watch --configuration=development",
    "dev:all": "nx run-many -t build --watch",
    "lint": "nx run-many -t lint -p ptah-extension-vscode ptah-extension-webview shared",
    "lint:extension": "nx lint ptah-extension-vscode",
    "lint:webview": "nx lint ptah-extension-webview",
    "lint:shared": "nx lint shared",
    "lint:all": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "typecheck:affected": "nx affected -t typecheck ",
    "typecheck:extension": "nx run ptah-extension-vscode:typecheck",
    "typecheck:webview": "nx run ptah-extension-webview:typecheck",
    "typecheck:shared": "nx run shared:typecheck",
    "typecheck:all": "nx affected -t typecheck",
    "test": "nx run-many -t test -p ptah-extension-vscode ptah-extension-webview shared",
    "test:extension": "nx test ptah-extension-vscode",
    "test:webview": "nx test ptah-extension-webview",
    "test:shared": "nx test shared",
    "test:all": "nx run-many -t test",
    "test:watch": "nx run-many -t test --watch",
    "test:e2e": "jest --config=e2e/jest.config.js --testPathPattern=e2e",
    "clean": "nx reset && rm -rf dist node_modules/.cache",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "package": "nx build ptah-extension-vscode && nx build ptah-extension-webview && vsce package --out dist/",
    "serve:webview": "nx serve ptah-extension-webview",
    "serve:extension": "nx serve ptah-extension-vscode",
    "prepare": "husky || true",
    "validate-skill": "npx ts-node scripts/validate-orchestration-skill.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~20.1.0",
    "@angular/compiler": "~20.1.0",
    "@angular/core": "~20.1.0",
    "@angular/forms": "~20.1.0",
    "@angular/platform-browser": "~20.1.0",
    "@angular/platform-browser-dynamic": "~20.1.0",
    "@angular/router": "~20.1.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@floating-ui/dom": "^1.7.4",
    "@github/copilot-sdk": "^0.1.25",
    "@hive-academy/angular-gsap": "^1.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@openai/codex-sdk": "^0.104.0",
    "@paddle/paddle-js": "^1.6.1",
    "@paddle/paddle-node-sdk": "^2.0.0",
    "@prisma/adapter-pg": "7.1.0",
    "@prisma/client": "7.1.0",
    "@sinclair/typebox": "^0.34.41",
    "async-mutex": "^0.5.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cross-spawn": "^7.0.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "eventemitter3": "^5.0.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "json2md": "^2.0.3",
    "jsonrepair": "^3.13.1",
    "lenis": "^1.3.17",
    "lucide-angular": "^0.542.0",
    "p-limit": "^7.1.1",
    "p-queue": "^8.1.0",
    "pg": "8.11.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.8.0",
    "rxjs": "~7.8.0",
    "three-nebula": "^10.0.3",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsyringe": "^4.10.0",
    "uuid": "^11.1.0",
    "which": "^6.0.1",
    "zod": "^4.1.12",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~20.1.0",
    "@angular-devkit/schematics": "~20.1.0",
    "@angular/build": "~20.1.0",
    "@angular/cdk": "^20.2.14",
    "@angular/cli": "~20.1.0",
    "@angular/compiler-cli": "~20.1.0",
    "@angular/language-service": "~20.1.0",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx-tools/nx-prisma": "^7.2.0",
    "@nx/angular": "21.4.1",
    "@nx/esbuild": "22.1.3",
    "@nx/eslint": "21.4.1",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/jest": "21.4.1",
    "@nx/js": "22.1.3",
    "@nx/nest": "^22.1.3",
    "@nx/node": "22.1.3",
    "@nx/web": "21.4.1",
    "@nx/webpack": "22.1.3",
    "@nx/workspace": "21.4.1",
    "@schematics/angular": "~20.1.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/cookie-parser": "^1.4.8",
    "@types/cross-spawn": "^6.0.6",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/json2md": "^1.5.4",
    "@types/node": "20.19.9",
    "@types/pg": "8.16.0",
    "@types/picomatch": "^4.0.2",
    "@types/three": "^0.181.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.103.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/utils": "^8.29.0",
    "@vscode/vsce": "^3.7.1",
    "@workos-inc/node": "^7.77.0",
    "angular-eslint": "^20.0.0",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.9.18",
    "daisyui": "^4.12.24",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "gsap": "^3.14.2",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-preset-angular": "~15.0.0",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^15.0.0",
    "marked": "^17.0.0",
    "ng-packagr": "~20.1.0",
    "ngx-markdown": "^21.0.0",
    "nx": "21.4.1",
    "postcss": "^8.5.6",
    "postcss-url": "~10.1.3",
    "prettier": "^2.6.2",
    "prisma": "7.1.0",
    "tailwindcss": "^3.4.18",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "ngx-markdown": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/browser": "$@angular/browser",
      "@angular/platform-browser": "$@angular/platform-browser"
    },
    "@anthropic-ai/claude-agent-sdk": {
      "zod": "^4.1.12"
    }
  }
}
