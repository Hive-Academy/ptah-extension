    "cookie-parser": "^1.4.7",
    "cross-spawn": "^7.0.6",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.0.0",
    "eventemitter3": "^5.0.1",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "json2md": "^2.0.3",
    "jsonrepair": "^3.13.1",
    "lucide-angular": "^1.0.0",
    "monaco-editor": "^0.55.1",
    "ngx-monaco-editor-v2": "^21.1.4",
    "p-limit": "^7.1.1",
    "p-queue": "^8.1.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.0",
    "rxjs": "~7.8.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "tsyringe": "^4.10.0",
    "uuid": "^11.1.0",
    "which": "^6.0.1",
    "zod": "^4.1.12",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.2.4",
