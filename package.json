    "@angular/compiler-cli": "21.2.6",
    "@angular/language-service": "21.2.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron/rebuild": "^3.6.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.2",
    "@nx-tools/nx-prisma": "^7.2.0",
    "@nx/angular": "22.6.1",
    "@nx/esbuild": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/nest": "22.6.1",
    "@nx/node": "22.6.1",
    "@nx/web": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@schematics/angular": "21.2.4",
    "@types/cookie-parser": "^1.4.8",
    "@types/cross-spawn": "^6.0.6",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
