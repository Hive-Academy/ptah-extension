

echo "🚀 Running pre-push checks..."

# Get the current branch
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Only run full checks if pushing to main or develop
if [ "$current_branch" = "main" ] || [ "$current_branch" = "develop" ]; then


  echo "🏗️ Building affected projects..."
  npx nx affected -t build --base=origin/$current_branch


  # Validate that all affected libraries can build and lint
  echo "🏗️ Building and linting affected projects..."
  npm run typecheck:affected

  echo "📦 Validating extension packaging..."
  npx nx package ptah-extension-vscode

else
  echo "ℹ️  Skipping full checks for feature branch: $current_branch"
fi

echo "✅ Pre-push checks passed!"
