#!/usr/bin/env sh

echo "🔍 Running pre-commit checks..."

# Run lint-staged
npx lint-staged --no-stash --concurrent false

# Check if orchestration skill files were changed
SKILL_FILES_CHANGED=$(git diff --cached --name-only | grep -E "^\.claude/skills/" || true)

if [ -n "$SKILL_FILES_CHANGED" ]; then
  echo "🔧 Orchestration skill files changed, running validation..."
  echo "   Changed files:"
  echo "$SKILL_FILES_CHANGED" | sed 's/^/     /'

  # Run skill validation
  npm run validate-skill

  if [ $? -ne 0 ]; then
    echo "❌ Skill validation failed! Please fix the errors before committing."
    exit 1
  fi

  echo "✅ Skill validation passed!"
fi

echo "🏗️  Verifying electron main bundle builds + native deps declared..."
if [ "${PTAH_PRECOMMIT_PARANOID:-0}" = "1" ]; then
  npx nx affected -t build --base=HEAD~1
else
  npx nx run ptah-electron:validate-deps
fi

if [ $? -ne 0 ]; then
  echo "❌ Build gate failed — electron main bundle failed to compile OR a runtime dep is missing from apps/ptah-electron/package.json (would crash with ERR_MODULE_NOT_FOUND in production)."
  echo "   Set PTAH_PRECOMMIT_PARANOID=1 to run full affected build instead."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
