# Network resilience for cold installs on DO App Platform / CI.
#
# The DigitalOcean nodejs buildpack does a full cold `npm install` of the
# whole monorepo whenever its cache is invalidated (e.g. Node version drift),
# which is large and reset-prone. A mid-download ECONNRESET aborts the build.
# Retry aggressively on transient network errors so the install self-heals.
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
