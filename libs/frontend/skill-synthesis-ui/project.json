{
  "name": "@ptah-extension/skill-synthesis-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend/skill-synthesis-ui/src",
  "prefix": "ptah",
  "projectType": "library",
  "tags": ["scope:webview", "type:feature", "platform:angular"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/frontend/skill-synthesis-ui/jest.config.ts",
        "tsConfig": "libs/frontend/skill-synthesis-ui/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx ngc --noEmit --project libs/frontend/skill-synthesis-ui/tsconfig.lib.json"
      }
    }
  }
}
