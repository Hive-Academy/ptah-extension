{
  "name": "skill-synthesis",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/backend/skill-synthesis/src",
  "tags": ["scope:extension", "type:feature"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/skill-synthesis",
        "main": "libs/backend/skill-synthesis/src/index.ts",
        "tsConfig": "libs/backend/skill-synthesis/tsconfig.lib.json",
        "assets": [],
        "format": ["cjs"],
        "external": ["vscode", "tsyringe", "better-sqlite3", "sqlite-vec"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/skill-synthesis/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project libs/backend/skill-synthesis/tsconfig.lib.json"
      }
    }
  }
}
