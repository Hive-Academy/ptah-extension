{
  "name": "@ptah-extension/agent-generation",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/backend/agent-generation/src",
  "projectType": "library",
  "tags": ["scope:extension", "type:feature"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/agent-generation",
        "main": "libs/backend/agent-generation/src/index.ts",
        "tsConfig": "libs/backend/agent-generation/tsconfig.lib.json",
        "assets": [
          "libs/backend/agent-generation/*.md",
          "libs/backend/agent-generation/templates/**/*.template.md"
        ],
        "deleteOutputPath": true,
        "format": ["cjs"],
        "external": ["vscode", "tsyringe", "eventemitter3", "rxjs"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/agent-generation/jest.config.ts"
      }
    }
  }
}
