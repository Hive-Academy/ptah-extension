{
  "name": "messaging-gateway",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/backend/messaging-gateway/src",
  "tags": ["scope:extension", "type:feature"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/backend/messaging-gateway",
        "main": "libs/backend/messaging-gateway/src/index.ts",
        "tsConfig": "libs/backend/messaging-gateway/tsconfig.lib.json",
        "assets": [],
        "format": ["cjs"],
        "external": [
          "vscode",
          "tsyringe",
          "better-sqlite3",
          "sqlite-vec",
          "grammy",
          "discord.js",
          "@slack/bolt",
          "ffmpeg-static",
          "nodejs-whisper"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/backend/messaging-gateway/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --project libs/backend/messaging-gateway/tsconfig.lib.json"
      }
    }
  }
}
